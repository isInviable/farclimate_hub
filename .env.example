# Direct Postgres connection string from Supabase Dashboard
# Settings > Database > Connection string (URI) — use "direct" not "pooled"
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Supabase HTTP API (used by packages/db loader to upload article images to Storage)
# Settings > API > Project URL
SUPABASE_URL=https://[project-ref].supabase.co
# Settings > API > service_role secret (server-only, keep private)
SUPABASE_SERVICE_ROLE_KEY=

# API Keys
NUXT_PUBLIC_ORAMA_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
NUXT_PUBLIC_MAPBOX_API_KEY=
